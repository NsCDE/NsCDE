# BackdropMgr
msgid "Style Manager - Window"
msgstr "样式管理器 - 窗口"

msgid "Default"
msgstr "默认"

msgid "Configuration Section: "
msgstr "配置部分： "

msgid " Window Behavior| Window Icons| Page Edges| Animation"
msgstr " 窗口行为| 窗口图标| 页面边缘| 动画"

msgid "Window Behavior"
msgstr "窗口行为"

msgid "Only Pointer Inside Window Makes Focus"
msgstr "仅指针进入窗口时获得焦点"

msgid "Point In Window To Make Active"
msgstr "指针进入窗口即激活"

msgid "Click In Window To Make Active"
msgstr "点击窗口激活"

msgid " Raise Window When Made Active        "
msgstr " 激活时提升窗口        "

msgid " Allow Primary Windows On Top            "
msgstr " 允许主窗口置顶            "

msgid " Lower Transient With Primary Window"
msgstr " 随主窗口降低瞬态窗口"

msgid " Raise/Lower Primaries With Transients"
msgstr " 随瞬态窗口提升/降低主窗口"

