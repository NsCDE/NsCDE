# Keybindings Help Dialog
msgid "GWM Key Bindings"
msgstr "GWM 键绑定"

msgid "The following keybindings are available for GWM:"
msgstr "GWM 可使用以下键绑定："

msgid "- Ctrl+M: Workspace -> Manage ..."
msgstr "- Ctrl+M: 工作区 -> 管理 ..."

msgid "- Ctrl+R: Workspace -> Rename ..."
msgstr "- Ctrl+R: 工作区 -> 重命名 ..."

msgid "- Ctrl+O: Workspace -> Options ..."
msgstr "- Ctrl+O: 工作区 -> 选项 ..."

msgid "- Ctrl+W: Window -> Occupy Workspace ..."
msgstr "- Ctrl+W: 窗口 -> 占用工作区 ..."

msgid "- F1: Help -> GWM Help"
msgstr "- F1: 帮助 -> GWM 帮助"

msgid "- Help: Help -> GWM Help"
msgstr "- Help: 帮助 -> GWM 帮助"

msgid "- Escape: Workspace -> Exit"
msgstr "- Escape: 工作区 -> 退出"

msgid "- Ctrl+Q: Workspace -> Exit"
msgstr "- Ctrl+Q: 工作区 -> 退出"

