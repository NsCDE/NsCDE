# DefaultAppsMgr

msgid "Style Manager - Default Applications"
msgstr "Upravljač Stila - Zadane Aplikacije"

msgid "Apply"
msgstr "Primjeni"

msgid "Save"
msgstr "Sačuvaj"

msgid "Close"
msgstr "Zatvori"

msgid "Help"
msgstr "Pomoć"

msgid "Terminal Emulator:"
msgstr "Emulator Terminala:"

msgid "Text Editor:"
