msgid "Applied. Changes are active for this session."
msgstr "Primijenjeno. Promjene su aktivne za ovu sesiju."

msgid "Saved to NsCDE.conf. Changes will persist after restart."
msgstr "Spremljeno u NsCDE.conf. Promjene će se nastaviti nakon ponovnog pokretanja."

msgid "Dismiss"
msgstr "Nestani"

msgid "Use this dialog to set default applications for common tasks. Select the desired application from each dropdown menu, then click Apply to test or Save to write changes to your NsCDE.conf configuration file."
msgstr "Koristite ovaj dijalog za postavljanje zadanih aplikacija za uobičajene zadatke. Odaberite željenu aplikaciju iz svakog padajućeg izbornika, zatim kliknite Primjeni za testiranje ili Sačuvaj za spremanje promjena u NsCDE.conf konfiguracijsku datoteku."
