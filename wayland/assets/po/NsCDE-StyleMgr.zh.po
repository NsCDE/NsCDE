# Key bindings cheat sheet message window
msgid "The following keybindings are available for Style Manager:"
msgstr "样式管理器可使用以下键绑定："

msgid "- Ctrl+Q: File -> Exit"
msgstr "- Ctrl+Q: 文件 -> 退出"

msgid "- F1, H, Help: Help -> Style Manager Help"
msgstr "- F1, H, Help: 帮助 -> 样式管理器帮助"

msgid "- C: Open Color Style Manager"
msgstr "- C: 打开颜色样式管理器"

msgid "- F: Open Font Style Manager"
msgstr "- F: 打开字体样式管理器"

msgid "- B: Open Backdrop Style Manager"
msgstr "- B: 打开背景样式管理器"

msgid "- K: Open Keyboard Style Manager"
msgstr "- K: 打开键盘样式管理器"

msgid "- M: Open Mouse Style Manager"
msgstr "- M: 打开鼠标样式管理器"

msgid "- E: Open Beep Style Manager"
msgstr "- E: 打开蜂鸣样式管理器"

msgid "- S: Open Screen Style Manager"
msgstr "- S: 打开屏幕样式管理器"

msgid "- W: Open Window Style Manager"
msgstr "- W: 打开窗口样式管理器"

msgid "- D: Open Workspaces and Pages Style Manager"
msgstr "- D: 打开工作区和页面样式管理器"

msgid "- P: Open Power Style Manager"
msgstr "- P: 打开电源样式管理器"

msgid "- T: Open Startup Style Manager"
msgstr "- T: 打开启动样式管理器"
