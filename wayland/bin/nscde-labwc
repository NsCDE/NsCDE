#!/bin/sh

set -eu

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
config_dir="$config_home/nscde-wayland"
labwc_config_dir="$config_dir/labwc"
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
wayland_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)

if [ -n "${NSCDE_WAYLAND_SOURCE:-}" ]; then
	source_dir=$NSCDE_WAYLAND_SOURCE
elif [ -d "$wayland_dir/labwc" ]; then
	source_dir=$wayland_dir
else
	source_dir=/usr/share/nscde-wayland
fi

asset_source=${NSCDE_WAYLAND_ASSET_SOURCE:-"$source_dir/assets"}
theme_source=${NSCDE_WAYLAND_THEME_SOURCE:-"$source_dir/themes/NsCDE-Wayland"}
labwc_source=${NSCDE_WAYLAND_LABWC_SOURCE:-"$source_dir/labwc"}

copy_file_once() {
	src=$1
	dst=$2
	if [ -f "$src" ] && [ ! -e "$dst" ]; then
		mkdir -p "$(dirname -- "$dst")"
		cp "$src" "$dst"
	fi
}

repair_labwc_mouse_defaults() {
	cfg=$labwc_config_dir/rc.xml
	[ -f "$cfg" ] || return
	grep -q 'ShowMenu" menu="root-menu"' "$cfg" || return
	if awk '
		/<mouse>/ { in_mouse=1 }
		in_mouse && /<default/ { found=1 }
		/<\/mouse>/ { in_mouse=0 }
		END { exit found ? 0 : 1 }
	' "$cfg"; then
		return
	fi
	tmp=$cfg.tmp.$$
	backup=$cfg.bak-before-mouse-default
	awk '
		/<mouse>/ && !done { print; print "    <default />"; done=1; next }
		{ print }
	' "$cfg" > "$tmp" || {
		rm -f "$tmp"
		return
	}
	[ -e "$backup" ] || cp "$cfg" "$backup"
	mv "$tmp" "$cfg"
}

repair_labwc_menu_scale() {
	cfg=$labwc_config_dir/menu.xml
	[ -f "$cfg" ] || return
	grep -q 'id="root-menu" label="NsCDE"' "$cfg" || return
	grep -q 'nscde-output-scale' "$cfg" && \
		grep -q 'nscde-wayland-doctor' "$cfg" && \
		grep -q 'nscde-wayland-screenshot' "$cfg" && return
	tmp=$cfg.tmp.$$
	backup=$cfg.bak-before-scale-menu
	awk '
		/<separator[[:space:]\/>]/ && !done {
			if (!screenshot) {
				print "    <item label=\"Screenshot Area\">"
				print "      <action name=\"Execute\" command=\"nscde-wayland-screenshot area\" />"
				print "    </item>"
			}
			if (!scale) {
				print "    <menu id=\"display-scale-menu\" label=\"Display Scale\">"
				print "      <item label=\"Scale 1.0x\">"
				print "        <action name=\"Execute\" command=\"nscde-output-scale 1\" />"
				print "      </item>"
				print "      <item label=\"Scale 1.5x\">"
				print "        <action name=\"Execute\" command=\"nscde-output-scale 1.5\" />"
				print "      </item>"
				print "      <item label=\"Scale 2.0x\">"
				print "        <action name=\"Execute\" command=\"nscde-output-scale 2\" />"
				print "      </item>"
				print "    </menu>"
			}
			if (!doctor) {
				print "    <item label=\"Session Diagnostics\">"
				print "      <action name=\"Execute\" command=\"nscde-wayland-run foot -e nscde-wayland-doctor\" />"
				print "    </item>"
			}
			done=1
		}
		/nscde-wayland-screenshot/ { screenshot=1 }
		/nscde-output-scale/ { scale=1 }
		/nscde-wayland-doctor/ { doctor=1 }
		{ print }
	' "$cfg" > "$tmp" || {
		rm -f "$tmp"
		return
	}
	[ -e "$backup" ] || cp "$cfg" "$backup"
	mv "$tmp" "$cfg"
}

repair_labwc_autostart_scale() {
	cfg=$labwc_config_dir/autostart
	[ -f "$cfg" ] || return
	grep -q 'nscde_assets=' "$cfg" || return
	grep -q 'apply_global_scale' "$cfg" && return
	tmp=$cfg.tmp.$$
	backup=$cfg.bak-before-scale-autostart
	awk '
		/^wallpaper=/ && !vars {
			print
			print "scale_file=${NSCDE_WAYLAND_SCALE_FILE:-\"${NSCDE_WAYLAND_CONFIG:-\"$HOME/.config/nscde-wayland\"}/scale\"}"
			print ""
			print "apply_global_scale() {"
			print "	scale=${NSCDE_WAYLAND_SCALE:-}"
			print "	if [ -z \"$scale\" ] && [ -r \"$scale_file\" ]; then"
			print "		IFS= read -r scale < \"$scale_file\" || scale="
			print "	fi"
			print "	case \"$scale\" in \"\"|*[!0123456789.]*|.*|*.*.*) return ;; esac"
			print "	command -v wlr-randr >/dev/null 2>&1 || return"
			print "	wlr-randr 2>/dev/null | while IFS= read -r line; do"
			print "		case \"$line\" in \"\"|\" \"*) continue ;; esac"
			print "		output=${line%% *}"
			print "		[ -n \"$output\" ] && wlr-randr --output \"$output\" --scale \"$scale\" >/dev/null 2>&1"
			print "	done"
			print "}"
			vars=1
			next
		}
		/kanshi/ && !hook {
			print
			print "if [ -n \"${NSCDE_WAYLAND_SCALE:-}\" ] || [ -r \"$scale_file\" ]; then"
			print "	(sleep 1; apply_global_scale) &"
			print "fi"
			hook=1
			next
		}
		{ print }
	' "$cfg" > "$tmp" || {
		rm -f "$tmp"
		return
	}
	[ -e "$backup" ] || cp "$cfg" "$backup"
	mv "$tmp" "$cfg"
}

repair_labwc_component_wrappers() {
	for cfg in "$labwc_config_dir/rc.xml" "$labwc_config_dir/menu.xml"; do
		[ -f "$cfg" ] || continue
		grep -q 'command="foot' "$cfg" || grep -q 'command="fuzzel"' "$cfg" || \
			grep -q 'command="pcmanfm-qt"' "$cfg" || continue
		tmp=$cfg.tmp.$$
		backup=$cfg.bak-before-wayland-run
		sed \
			-e 's/command="foot -e nscde-wayland-doctor"/command="nscde-wayland-run foot -e nscde-wayland-doctor"/g' \
			-e 's/command="foot"/command="nscde-wayland-run foot"/g' \
			-e 's/command="fuzzel"/command="nscde-wayland-run fuzzel"/g' \
			-e 's/command="pcmanfm-qt"/command="nscde-wayland-run app pcmanfm-qt"/g' \
			"$cfg" > "$tmp" || {
				rm -f "$tmp"
				continue
			}
		[ -e "$backup" ] || cp "$cfg" "$backup"
		mv "$tmp" "$cfg"
	done

	cfg=$labwc_config_dir/autostart
	[ -f "$cfg" ] || return
	grep -q '&& fnott &' "$cfg" || grep -q '&& sfwbar &' "$cfg" || return
	tmp=$cfg.tmp.$$
	backup=$cfg.bak-before-wayland-run
	sed \
		-e 's/&& fnott &/\&\& nscde-wayland-run fnott \&/g' \
		-e 's/&& sfwbar &/\&\& nscde-wayland-run sfwbar \&/g' \
		"$cfg" > "$tmp" || {
			rm -f "$tmp"
			return
		}
	[ -e "$backup" ] || cp "$cfg" "$backup"
	mv "$tmp" "$cfg"
}

mkdir -p "$labwc_config_dir"
copy_file_once "$labwc_source/rc.xml" "$labwc_config_dir/rc.xml"
copy_file_once "$labwc_source/menu.xml" "$labwc_config_dir/menu.xml"
copy_file_once "$labwc_source/autostart" "$labwc_config_dir/autostart"
repair_labwc_mouse_defaults
repair_labwc_menu_scale
repair_labwc_autostart_scale
repair_labwc_component_wrappers

export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=nscde-labwc
export XDG_CURRENT_DESKTOP=NsCDE:labwc
export GDK_BACKEND=wayland
export QT_QPA_PLATFORM=wayland
export MOZ_ENABLE_WAYLAND=1
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export NSCDE_WAYLAND_CONFIG="$config_dir"
export NSCDE_WAYLAND_DATA="$source_dir"
export NSCDE_WAYLAND_ASSETS="$asset_source"
export NSCDE_BASE_XDG_CONFIG_DIRS="${XDG_CONFIG_DIRS:-/etc/xdg}"
export NSCDE_BASE_XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
export PATH="$script_dir:$PATH"
export XCURSOR_PATH="$asset_source/icons:${XCURSOR_PATH:-}"

exec labwc -C "$labwc_config_dir" "$@"
