#!/bin/sh

set -eu

mode=${1:-area}
output=${2:-}

usage() {
	printf '%s\n' "usage: nscde-wayland-screenshot [area|full|copy-area|copy-full] [output.png]" >&2
	exit 2
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || {
		printf '%s\n' "missing required command: $1" >&2
		exit 1
	}
}

default_output() {
	dir=${XDG_PICTURES_DIR:-"$HOME/Pictures"}/Screenshots
	mkdir -p "$dir"
	printf '%s/NsCDE-%s.png\n' "$dir" "$(date +%Y%m%d-%H%M%S)"
}

select_area() {
	geometry=$(slurp) || exit 1
	[ -n "$geometry" ] || exit 1
	printf '%s\n' "$geometry"
}

case "$mode" in
	area)
		need_cmd grim
		need_cmd slurp
		[ -n "$output" ] || output=$(default_output)
		grim -g "$(select_area)" "$output"
		printf '%s\n' "$output"
		;;
	full)
		need_cmd grim
		[ -n "$output" ] || output=$(default_output)
		grim "$output"
		printf '%s\n' "$output"
		;;
	copy-area)
		need_cmd grim
		need_cmd slurp
		need_cmd wl-copy
		grim -g "$(select_area)" - | wl-copy -t image/png
		;;
	copy-full)
		need_cmd grim
		need_cmd wl-copy
		grim - | wl-copy -t image/png
		;;
	*)
		usage
		;;
esac
