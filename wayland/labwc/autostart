#!/bin/sh

nscde_assets=${NSCDE_WAYLAND_ASSETS:-/usr/share/nscde-wayland/assets}
wallpaper="$nscde_assets/photos/Flower.png"

command -v fnott >/dev/null 2>&1 && fnott &
command -v kanshi >/dev/null 2>&1 && kanshi &
command -v sfwbar >/dev/null 2>&1 && sfwbar &
command -v lavalauncher >/dev/null 2>&1 && lavalauncher &

if [ -f "$wallpaper" ]; then
	if command -v swaybg >/dev/null 2>&1; then
		swaybg -i "$wallpaper" -m fill &
	elif command -v wbg >/dev/null 2>&1; then
		wbg "$wallpaper" &
	fi
fi
