<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
  <menu id="root-menu" label="NsCDE">
    <item label="Terminal">
      <action name="Execute" command="nscde-wayland-run foot" />
    </item>
    <item label="File Manager">
      <action name="Execute" command="nscde-wayland-run app pcmanfm-qt" />
    </item>
    <item label="Run">
      <action name="Execute" command="nscde-wayland-run fuzzel" />
    </item>
    <item label="Screenshot Area">
      <action name="Execute" command="nscde-wayland-screenshot area" />
    </item>
    <menu id="display-scale-menu" label="Display Scale">
      <item label="Scale 1.0x">
        <action name="Execute" command="nscde-output-scale 1" />
      </item>
      <item label="Scale 1.5x">
        <action name="Execute" command="nscde-output-scale 1.5" />
      </item>
      <item label="Scale 2.0x">
        <action name="Execute" command="nscde-output-scale 2" />
      </item>
    </menu>
    <item label="Session Diagnostics">
      <action name="Execute" command="nscde-wayland-run foot -e nscde-wayland-doctor" />
    </item>
    <separator />
    <item label="Reconfigure">
      <action name="Reconfigure" />
    </item>
    <item label="Exit">
      <action name="Exit" />
    </item>
  </menu>
</openbox_menu>
