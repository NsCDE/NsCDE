Set Term = "nscde-wayland-run foot"
IconTheme = "NsCDE"

include("winops.widget")

function("SfwbarInit") {
  SetLayer "panel", "bottom"
  SetExclusiveZone "panel", "58"
}

layout "panel" {
  size = "100%"
  layer = "bottom"
  exclusive_zone = "auto"

  button {
    value = "start-here"
    action = Exec "nscde-wayland-run fuzzel"
    tooltip = "Run"
  }
  button {
    value = "utilities-terminal"
    action = Exec $Term
    tooltip = "Terminal"
  }
  button {
    value = "system-file-manager"
    action = Exec "nscde-wayland-run app pcmanfm-qt"
    tooltip = "File Manager"
  }
  button {
    value = "camera-photo"
    action = Exec "nscde-wayland-screenshot area"
    tooltip = "Screenshot Area"
  }
  button {
    value = "preferences-system"
    action = Exec "nscde-wayland-run app nwg-look"
    tooltip = "Style"
  }
  taskbar {
    rows = 1
    group = false
    icons = true
    labels = true
    title_width = 24
    css = "* { -GtkWidget-hexpand: true; }"
    action[RightClick] = Menu "winops"
  }
  tray {
    rows = 1
  }
  grid {
    css = "* { -GtkWidget-direction: bottom; padding: 3px 8px; }"
    label {
      value = Time("%H:%M")
      interval = 1000
    }
    label {
      value = Time("%Y-%m-%d")
      interval = 60000
    }
  }
}

window#panel {
  -GtkWidget-direction: top;
  background-color: #b8b8b8;
  border-top: 2px solid #ffffff;
  border-left: 2px solid #ffffff;
  border-right: 2px solid #5f5f5f;
  border-bottom: 2px solid #4a4a4a;
  color: #000000;
}

button,
button image,
label {
  color: #000000;
  font: 12px Sans;
  outline-style: none;
  box-shadow: none;
  background-image: none;
  border-image: none;
}

button {
  margin: 2px;
  padding: 4px 8px;
  border-radius: 0;
  border-top: 2px solid #ffffff;
  border-left: 2px solid #ffffff;
  border-right: 2px solid #5a5a5a;
  border-bottom: 2px solid #4a4a4a;
  background-color: #c7c7c7;
}

button:hover {
  background-color: #d3d3d3;
}

button:active,
button#taskbar_item.focused {
  border-top: 2px solid #4a4a4a;
  border-left: 2px solid #5a5a5a;
  border-right: 2px solid #ffffff;
  border-bottom: 2px solid #ffffff;
  background-color: #9fb4cf;
}

button image,
button#tray_item image {
  min-width: 22px;
  min-height: 22px;
  padding: 0;
}

button#taskbar_item {
  min-height: 32px;
  padding: 3px 8px;
}

button#taskbar_item image {
  padding-right: 6px;
}

button#tray_item {
  padding: 2px;
}

grid {
  margin: 0;
}
