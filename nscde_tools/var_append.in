export TEXTDOMAINDIR="$NSCDE_ROOT/share/locale"
export TEXTDOMAIN="nscde-tools"

# Handle gettext absence
function _echo { shift; echo "$@"; }
whence -q gettext
if (($? != 0)); then
   alias gettext="_echo"
fi

valsep="$1"
varname="$2"
varnewval="$3"

if [ "$valsep" == "__space__" ]; then
   valsep=" "
fi

eval varcontent='$'$varname

for argv in "$valsep" "$varname" "$varnewval"
do
   if [ "x$argv" == "x" ]; then
      gettext -s "Usage: ${0##*/} <separator> <varname> <varvalue>" >&2
      if [ "x$varname" != "x" ]; then
         echo "$varcontent"
      fi
      exit 1
   fi
done

echo "$varcontent" | tr "$valsep" "\n" | egrep -wq "$varnewval"
if (($? != 0)); then
   if [ "$varcontent" == "" ]; then
      export $varname="${varnewval}"
   else
      export $varname="${varcontent}${valsep}${varnewval}"
   fi
fi

if [ "x$varname" != "x" ]; then
   eval echo '$'$varname
fi
