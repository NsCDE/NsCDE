# Mode flags for DefaultAppsMgr dialog:
# -M <CatName>              : Menu mode - list all installed apps (pipe-separated)
# -S <CatName> <appname>    : Select mode - find 1-based index of appname
# -G <CatName> <index>      : Get mode - get appname by 1-based index
# Default (no flag): <InfVarName> <CatName> - find first available app

MODE="default"

if [ "x$1" == "x" ]; then
   echo "NOARG"
   exit 1
fi

# Check for mode flags
case "$1" in
   -M|-S|-G)
      MODE="$1"
      shift
      CatName="$1"
      ;;
   *)
      InfVarName="$1"
      ;;
esac

if [ "x$2" == "x" ]; then
   if [ "$MODE" == "default" ]; then
      echo "NOARG"
      exit 1
   fi
else
   if [ "$MODE" == "default" ]; then
      CatName="$2"
   fi
fi

if [ ! -r "$NSCDE_DATADIR/fallback/app-catalog/$CatName" ]; then
   echo "NOCATALOG"
   exit 2
fi

# Menu mode: list all installed apps from catalog (pipe-separated for FvwmScript PopupMenu)
if [ "$MODE" == "-M" ]; then
   menu=""
   while read appname; do
      # Skip infostore references
      echo "$appname" | grep -E -q '^\$\[infostore\..*\]'
      if (($? == 0)); then
         continue
      fi
      # Handle needterm entries
      appname0="${appname%% *}"
      appname3="${appname##*:}"
      if [ "${appname3}" == "needterm" ]; then
         appname4="${appname/:needterm/}"
         if $(whence -q ${appname4}); then
            if [ "x$menu" == "x" ]; then
               menu="$appname4"
            else
               menu="$menu|$appname4"
            fi
         fi
      else
         if $(whence -q ${appname0}); then
            if [ "x$menu" == "x" ]; then
               menu="$appname"
            else
               menu="$menu|$appname"
            fi
         fi
      fi
   done < "$NSCDE_DATADIR/fallback/app-catalog/$CatName"
   if [ "x$menu" == "x" ]; then
      echo "(none found)"
   else
      echo "$menu"
   fi
   exit 0
fi

# Select mode: find 1-based index of appname in installed apps list
if [ "$MODE" == "-S" ]; then
   target="$2"
   idx=0
   found=0
   while read appname; do
      echo "$appname" | grep -E -q '^\$\[infostore\..*\]'
      if (($? == 0)); then
         continue
      fi
      appname0="${appname%% *}"
      appname3="${appname##*:}"
      if [ "${appname3}" == "needterm" ]; then
         appname4="${appname/:needterm/}"
         if $(whence -q ${appname4}); then
            idx=$((idx + 1))
            if [ "$appname4" == "$target" ]; then
               echo "$idx"
               found=1
               break
            fi
         fi
      else
         if $(whence -q ${appname0}); then
            idx=$((idx + 1))
            if [ "$appname" == "$target" ]; then
               echo "$idx"
               found=1
               break
            fi
         fi
      fi
   done < "$NSCDE_DATADIR/fallback/app-catalog/$CatName"
   if (($found == 0)); then
      echo "1"
   fi
   exit 0
fi

# Get mode: get appname by 1-based index from installed apps list
if [ "$MODE" == "-G" ]; then
   target_idx="$2"
   idx=0
   found=0
   while read appname; do
      echo "$appname" | grep -E -q '^\$\[infostore\..*\]'
      if (($? == 0)); then
         continue
      fi
      appname0="${appname%% *}"
      appname3="${appname##*:}"
      if [ "${appname3}" == "needterm" ]; then
         appname4="${appname/:needterm/}"
         if $(whence -q ${appname4}); then
            idx=$((idx + 1))
            if [ "$idx" == "$target_idx" ]; then
               echo "$appname4"
               found=1
               break
            fi
         fi
      else
         if $(whence -q ${appname0}); then
            idx=$((idx + 1))
            if [ "$idx" == "$target_idx" ]; then
               echo "$appname"
               found=1
               break
            fi
         fi
      fi
   done < "$NSCDE_DATADIR/fallback/app-catalog/$CatName"
   if (($found == 0)); then
      echo "xterm"
   fi
   exit 0
fi

# For browser, first try environment, then XDG
if [ "$CatName" == "www-browser" ]; then
   if [ "x$BROWSER" != "x" ]; then
      whence -q $BROWSER
      if (($? == 0)); then
         echo $BROWSER
         exit 0
      fi
   fi

   whence -q xdg-settings
   if (($? == 0)); then
      candidate_raw=$(xdg-settings get default-web-browser)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               echo "${c}"
               exit 0
            fi
      done
      fi

      candidate_raw=$(xdg-settings get default-url-scheme-handler htts)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               echo "${c}"
               exit 0
            fi
         done
      fi
   
      candidate_raw=$(xdg-settings get default-url-scheme-handler http)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               echo "${c}"
               exit 0
            fi
         done
      fi
   fi
   
   whence -q xdg-mime
   if (($? == 0)); then
      candidate_raw=$(xdg-mime query default x-scheme-handler/https)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               echo "${c}"
               exit 0
            fi
         done
      fi
   
      candidate_raw=$(xdg-mime query default x-scheme-handler/http)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               echo "${c}"
               exit 0
            fi
         done
      fi
   fi
fi

if [ "$CatName" == "mailreader" ]; then
   whence -q xdg-mime
   if (($? == 0)); then
      candidate_raw=$(xdg-mime query default x-scheme-handler/mailto)
      candidate="${candidate_raw%.desktop}"
      if [ "x${candidate}" != "x" ]; then
         for c in "${candidate}" "${candidate}-stable" "${candidate}-bin" "${candidate}.bin"
         do
            whence -q "${c}"
            if (($? == 0)); then
               if [ "$c" != "mutt" ]; then
                  echo "${c}"
               else
                  echo "\$[infostore.terminal] -e ${c}"
               fi
               exit 0
            fi
         done
      fi
   fi
fi

found=0
cat "$NSCDE_DATADIR/fallback/app-catalog/$CatName" | while read appname
do
   echo "$appname" | grep -E -q '^\$\[infostore\..*\]'
   if (($? == 0)); then
      found=1
      echo "$appname"
      break
   fi

   # appname: top -c 3:needterm
   appname0="${appname%% *}"         # top
   appname1="${appname#* }"          # -c 3:needterm
   appname2="${appname1/:needterm/}" # -c 3
   appname3="${appname##*:}"         # needterm

   if [ "${appname3}" == "needterm" ]; then
      appname4="${appname/:needterm/}"
      if $(whence -q ${appname4}); then
         echo "\$[infostore.terminal] -e $appname4"
         found=1
         break
      fi
   fi

   if $(whence -q ${appname0}); then
      if [ "${appname3}" == "needterm" ]; then
         appname4="${appname/:needterm/}"
         echo "\$[infostore.terminal] -e $appname4"
      else
         echo $appname
      fi
      found=1
      break
   fi
done

if (($found == 0)); then
   echo "nscde_fvwmclnt 'f_NoApp NOAPP $InfVarName'"
fi

