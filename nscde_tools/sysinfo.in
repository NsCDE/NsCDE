import platform
import os
import pwd
import socket

# User Name
print (pwd.getpwuid(os.getuid()).pw_name)

# Workstation Name
print (platform.node().split(".", 1)[0])

# Uname mpi
print (platform.processor(), platform.machine(), os.uname()[4])

try:
    # Internet (IP) Address
    print (socket.gethostbyname(socket.gethostname()))
except Exception:
    print ("(none)")

# Internet Domain
try:
    finddomain = socket.getfqdn(socket.gethostbyname(socket.gethostname()))
    domainpart = finddomain.split(".", 1)[1]
    print (domainpart)
except Exception:
    print ("(none)")

try:
   import psutil

   physmem_mb = int(psutil.virtual_memory()[0] / 1024 / 1024)
   swapmem_mb = int(psutil.swap_memory()[0] / 1024 / 1024)
   swapmem_avail = int(psutil.swap_memory()[2] / 1024 / 1024)
   swapmem_pct = int(psutil.swap_memory()[3])

   # Physical Memory (RAM)
   print (physmem_mb)

   # Virtual Memory (Swap)
   print (swapmem_mb)

   # Virtual Memory (Swap) percent
   print (swapmem_pct)

   # Virtual Memory in Use
   print (str(swapmem_pct) + "% " + "(" + str(swapmem_pct) + "/" + str(swapmem_mb) + ") " + str(swapmem_avail) + "MB")

except ImportError:
   physmem_mb = "(Not available)"
   swapmem_mb = "(Not available)"
   swapmem_avail = "(Not available)"
   swapmem_pct = "(Not available)"

   # Physical Memory (RAM)
   print (physmem_mb)

   # Virtual Memory (Swap)
   print (swapmem_mb)

   # Virtual Memory (Swap) percent
   print (swapmem_pct)

   # Virtual Memory in Use
   print ("(Not available)")

# System Last Booted
try:
   import subprocess
   boot_time = subprocess.check_output(['uptime', '-s']).decode().strip()
   print (boot_time)
except Exception:
   try:
      import time
      with open('/proc/uptime', 'r') as f:
         uptime_seconds = float(f.readline().split()[0])
         boot_timestamp = time.time() - uptime_seconds
         boot_time = time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(boot_timestamp))
         print (boot_time)
   except Exception:
      print ("(Not available)")
