#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

%:
	dh $@ --without autoreconf

override_dh_auto_configure:
	dh_auto_configure -- \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libdir=/usr/lib

override_dh_auto_build:
	touch aclocal.m4 configure
	find . -name Makefile.in -exec touch {} +
	dh_auto_build

execute_after_dh_auto_install:
	mkdir -p debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH)/NsCDE
	mkdir -p debian/tmp/usr/libexec/NsCDE/$(DEB_HOST_MULTIARCH)
	find debian/tmp/usr/lib/NsCDE -path '*/Linux_*/*' -name XOverrideFontCursor.so -exec mv -t debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH)/NsCDE {} +
	find debian/tmp/usr/libexec/NsCDE -path '*/Linux_*/*' \( -name colorpicker -o -name fpclock \) -exec mv -t debian/tmp/usr/libexec/NsCDE/$(DEB_HOST_MULTIARCH) {} +
	# Debian relocates native helpers to DEB_HOST_MULTIARCH paths; adjust upstream wrappers.
	sed -i 's#\$${NSCDE_TOOLSDIR}/\$${OS_PLUS_MACHINE_ARCH}/colorpicker#$${NSCDE_TOOLSDIR}/$(DEB_HOST_MULTIARCH)/colorpicker#g' debian/tmp/usr/libexec/NsCDE/colorpicker
	sed -i 's#\$${NSCDE_TOOLSDIR}/\$${NSCDE_OS}_\$${MARCH}/fpclock#$${NSCDE_TOOLSDIR}/$(DEB_HOST_MULTIARCH)/fpclock#g' debian/tmp/usr/libexec/NsCDE/fpclock
	sed -i 's#\$$NSCDE_LIBDIR/\$$OS_PLUS_MACHINE_ARCH/XOverrideFontCursor\.so#/usr/lib/$(DEB_HOST_MULTIARCH)/NsCDE/XOverrideFontCursor.so#g' debian/tmp/usr/lib/NsCDE/fvwm-modules/FvwmScript
	find debian/tmp/usr/lib/NsCDE debian/tmp/usr/libexec/NsCDE -type d -empty -delete

execute_after_dh_fixperms:
	chmod 0644 debian/nscde-data/usr/lib/NsCDE/python/*.py
	chmod 0644 debian/nscde-data/usr/libexec/NsCDE/style_managers.shlib

override_dh_auto_clean:
	# Avoid upstream distclean: it tries to regenerate autotools files.
	true

override_dh_clean:
	dh_clean -Xautom4te.cache
