# nscde-tools: acpimgr.in

msgid "Error: Unknown ACPI operation mode."
msgstr "错误：未知的 ACPI 操作模式。"

msgid "Notice: Hibernate to disk is not supported on NetBSD."
msgstr "注意：NetBSD 不支持休眠到磁盘。"

msgid "Not available on $OS"
msgstr "在 $OS 上不可用"

msgid "Notice: Hybrid suspend is not supported on NetBSD."
msgstr "注意：NetBSD 不支持混合挂起。"

msgid "Notice: Hybrid suspend is not supported on OpenBSD."
msgstr "注意：OpenBSD 不支持混合挂起。"

msgid "Usage: ${0##*/} [ suspend | hibernate | hybrid-suspend | poweroff | reboot ] [ opmode ]"
msgstr "用法：${0##*/} [ suspend | hibernate | hybrid-suspend | poweroff | reboot ] [ opmode ]"

# nscde-tools: backdropmgr.in, colormgr.in

msgid "Error: cannot source ${NSCDE_TOOLSDIR}/style_managers.shlib."
msgstr "错误：无法加载 ${NSCDE_TOOLSDIR}/style_managers.shlib。"

msgid "Error: convert of photo $PhotoNamePath did not suceeded."
msgstr "错误：转换照片 $PhotoNamePath 失败。"

msgid "Error getting image path for $1."
msgstr "错误：无法获取 $1 的图片路径。"

# nscde-tools: colormgr.in

msgid "Error: Cannot open ${NSCDE_DATADIR}/config_templates/progbits/FullPalette.xpm"
msgstr "错误：无法打开 ${NSCDE_DATADIR}/config_templates/progbits/FullPalette.xpm"

msgid "Not performing pixmap modification in preview mode."
msgstr "预览模式下不执行像素图修改。"

msgid "Usage: ${BaseName} [ -p <Palette Name> ] [ -n <No of Colors> ] [ -5 | -8 ] [ -w ] [ -m ]"
msgstr "用法：${BaseName} [ -p <色板名称> ] [ -n <颜色数量> ] [ -5 | -8 ] [ -w ] [ -m ]"

# nscde-tools: chtheme.in

msgid "Palette $palette_name was not found. Path: \"$palette_path\"."
msgstr "未找到色板 $palette_name。路径：\"$palette_path\"。"

# nscde-tools: fontmgr.in

msgid "Error: NSCDE_ROOT is not set. Exiting."
msgstr "错误：NSCDE_ROOT 未设置。退出。"

msgid "Error: NSCDE_DATADIR is not set. Exiting."
msgstr "错误：NSCDE_DATADIR 未设置。退出。"

msgid "Error: fc-list command not found."
msgstr "错误：未找到 fc-list 命令。"

msgid "No NSCDE_ROOT defined. Exiting."
msgstr "未定义 NSCDE_ROOT。退出。"

msgid "No NSCDE_DATADIR defined. Exiting."
msgstr "未定义 NSCDE_DATADIR。退出。"

msgid "Usage: ${0##*/} [ -f <file> ] [ -v(ariable) | -m(onospaced) ] [ -t <normal | bold | italic> ] [ -s <small | medium | large> ] [ -S ] [ -Z maxsize ] [ -F ] [ -h ]"
msgstr "用法：${0##*/} [ -f <文件> ] [ -v(ariable) | -m(onospaced) ] [ -t <normal | bold | italic> ] [ -s <small | medium | large> ] [ -S ] [ -Z 最大大小 ] [ -F ] [ -h ]"

# nscde-tools: fpdoc.in

msgid "Error: ${0##*/}: Empty subpanel search for line ${LineInSubpanel} in subpanel ${SubpanelNo}"
msgstr "错误：${0##*/}：在子面板 ${SubpanelNo} 中搜索第 ${LineInSubpanel} 行时结果为空"

msgid "Error: ${0##*/}: Unknown mode of operation."
msgstr "错误：${0##*/}：未知的操作模式。"

# nscde-tools: fp_manage_subpanel.in

msgid "Error: HOME is not set cannot continue."
msgstr "错误：HOME 未设置，无法继续。"

msgid "Error: NSCDE_ROOT is not set cannot continue."
msgstr "错误：NSCDE_ROOT 未设置，无法继续。"

msgid "Error: NSCDE_ROOT does not exist. Cannot continue."
msgstr "错误：NSCDE_ROOT 不存在。无法继续。"

msgid "Error: NSCDE_DATADIR is not set cannot continue."
msgstr "错误：NSCDE_DATADIR 未设置，无法继续。"

msgid "Error: NSCDE_DATADIR does not exist. Cannot continue."
msgstr "错误：NSCDE_DATADIR 不存在。无法继续。"

msgid "Error: FVWM_USERDIR is not set cannot continue."
msgstr "错误：FVWM_USERDIR 未设置，无法继续。"

msgid "ERROR: Missing subpanel number."
msgstr "错误：缺少子面板编号。"

msgid "ERROR: Cannot open $NSCDE_DATADIR/defaults/Subpanels.actions for reading."
msgstr "错误：无法打开 $NSCDE_DATADIR/defaults/Subpanels.actions 进行读取。"

msgid "ERROR: invalid configuration for subpanel ${SubpanelNo} in $FVWM_USERDIR/Subpanels.actions."
msgstr "错误：$FVWM_USERDIR/Subpanels.actions 中子面板 ${SubpanelNo} 的配置无效。"

# nscde-tools: generate_subpanels.in

msgid "Error: FVWM_USERDIR is not set."
msgstr "错误：FVWM_USERDIR 未设置。"

# nscde-tools: getfont.in

msgid "No $NSCDE_DATADIR set. Exiting."
msgstr "未设置 $NSCDE_DATADIR。退出。"

msgid "No $FVWM_USERDIR set. Exiting."
msgstr "未设置 $FVWM_USERDIR。退出。"

msgid "Error: Cannot read $FnFile"
msgstr "错误：无法读取 $FnFile"

# nscde-tools: ised.in

msgid "Error: ${0##*/}: Cannot find GNU sed."
msgstr "错误：${0##*/}：找不到 GNU sed。"

msgid "Usage: ${0##*/} -s <sedopts> -c <sedcode> [ -f <inputfile> ] [ -h ]"
msgstr "用法：${0##*/} -s <sed选项> -c <sed代码> [ -f <输入文件> ] [ -h ]"

# nscde-tools: style_managers.shlib.in

# Note: "No NSCDE_ROOT defined. Exiting." and "No NSCDE_DATADIR defined. Exiting."
# are already listed under fontmgr.in and shared via the library.

# nscde-tools: var_append.in

msgid "Usage: ${0##*/} <separator> <varname> <varvalue>"
msgstr "用法：${0##*/} <分隔符> <变量名> <变量值>"

# nscde-tools: xdowrapper.in

msgid "No xdotool found. Exiting."
msgstr "未找到 xdotool。退出。"

msgid "Refreshing subpanel NsCDE-Subpanel${subp}"
msgstr "正在刷新子面板 NsCDE-Subpanel${subp}"

msgid "Error: NSCDE_TOOLSDIR is not defined."
msgstr "错误：NSCDE_TOOLSDIR 未定义。"
