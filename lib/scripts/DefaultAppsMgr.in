UseGettext {$NSCDE_ROOT/share/locale;NsCDE-DefaultAppsMgr}
WindowLocaleTitle {Style Manager - Default Applications}
WindowSize 520 460
Colorset 22

Init
Begin
   Set $DefFont = (GetOutput {$NSCDE_TOOLSDIR/getfont -v -t normal -s medium -Z 12} 1 -1)
   Set $LabelFont = (GetOutput {$NSCDE_TOOLSDIR/getfont -v -t normal -s medium -Z 11} 1 -1)
   Set $BtnFont = (GetOutput {$NSCDE_TOOLSDIR/getfont -v -t normal -s medium -Z 14} 1 -1)

   # Labels
   ChangeFont 10 $LabelFont
   ChangeFont 11 $LabelFont
   ChangeFont 12 $LabelFont
   ChangeFont 13 $LabelFont
   ChangeFont 14 $LabelFont
   ChangeFont 15 $LabelFont
   ChangeFont 16 $LabelFont
   ChangeFont 17 $LabelFont

   # PopupMenus
   ChangeFont 20 $DefFont
   ChangeFont 21 $DefFont
   ChangeFont 22 $DefFont
   ChangeFont 23 $DefFont
   ChangeFont 24 $DefFont
   ChangeFont 25 $DefFont
   ChangeFont 26 $DefFont
   ChangeFont 27 $DefFont

   # Buttons
   ChangeFont 1 $BtnFont
   ChangeFont 2 $BtnFont
   ChangeFont 3 $BtnFont
   ChangeFont 4 $BtnFont

   # Build app menus from catalogs
   # Terminal
   Set $TermMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M terminal} 1 -1)
   ChangeTitle 20 $TermMenu
   Set $TermCurrent = (GetOutput {echo $[infostore.terminal]} 1 -1)
   Set $TermSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S terminal "} $TermCurrent {"} 1 1)
   ChangeValue 20 $TermSel

   # Text Editor
   Set $EditorMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M text-editor} 1 -1)
   ChangeTitle 21 $EditorMenu
   Set $EditorCurrent = (GetOutput {echo $[infostore.xeditor]} 1 -1)
   Set $EditorSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S text-editor "} $EditorCurrent {"} 1 1)
   ChangeValue 21 $EditorSel

   # File Manager
   Set $FileMgrMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M filemgr} 1 -1)
   ChangeTitle 22 $FileMgrMenu
   Set $FileMgrCurrent = (GetOutput {echo $[infostore.filemgr]} 1 -1)
   Set $FileMgrSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S filemgr "} $FileMgrCurrent {"} 1 1)
   ChangeValue 22 $FileMgrSel

   # Web Browser
   Set $BrowserMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M www-browser} 1 -1)
   ChangeTitle 23 $BrowserMenu
   Set $BrowserCurrent = (GetOutput {echo $[infostore.browser]} 1 -1)
   Set $BrowserSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S www-browser "} $BrowserCurrent {"} 1 1)
   ChangeValue 23 $BrowserSel

   # Mail Reader
   Set $MailMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M mailreader} 1 -1)
   ChangeTitle 24 $MailMenu
   Set $MailCurrent = (GetOutput {echo $[infostore.mailreader]} 1 -1)
   Set $MailSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S mailreader "} $MailCurrent {"} 1 1)
   ChangeValue 24 $MailSel

   # Task Manager
   Set $TaskMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M taskmgr} 1 -1)
   ChangeTitle 25 $TaskMenu
   Set $TaskCurrent = (GetOutput {echo $[infostore.taskmgr]} 1 -1)
   Set $TaskSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S taskmgr "} $TaskCurrent {"} 1 1)
   ChangeValue 25 $TaskSel

   # Calculator
   Set $CalcMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M calculator} 1 -1)
   ChangeTitle 26 $CalcMenu
   Set $CalcCurrent = (GetOutput {echo $[infostore.calculator]} 1 -1)
   Set $CalcSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S calculator "} $CalcCurrent {"} 1 1)
   ChangeValue 26 $CalcSel

   # Print Manager
   Set $PrintMenu = (GetOutput {$NSCDE_TOOLSDIR/appfinder -M printmgr} 1 -1)
   ChangeTitle 27 $PrintMenu
   Set $PrintCurrent = (GetOutput {echo $[infostore.printmgr]} 1 -1)
   Set $PrintSel = (GetOutput {$NSCDE_TOOLSDIR/appfinder -S printmgr "} $PrintCurrent {"} 1 1)
   ChangeValue 27 $PrintSel

   # Store original values for change detection
   Set $OrigTerminal = $TermCurrent
   Set $OrigEditor = $EditorCurrent
   Set $OrigFileMgr = $FileMgrCurrent
   Set $OrigBrowser = $BrowserCurrent
   Set $OrigMail = $MailCurrent
   Set $OrigTask = $TaskCurrent
   Set $OrigCalc = $CalcCurrent
   Set $OrigPrint = $PrintCurrent

   # Key bindings
   Key Escape A 3 1 {KeyClose}
   Key Q C 3 1 {KeyClose}
   Key Return C 2 2 {KeySave}
   Key F1 A 4 1 {KeyHelp}
   Key Help A 4 1 {KeyHelp}
End

Widget 1
   Property
   Size 86 0
   Position 10 418
   Flags NoReliefString
   Type PushButton
   LocaleTitle {Apply}
   Main
      Case message of
      SingleClic :
      Begin
         SendSignal 50 1
      End
End

Widget 2
   Property
   Size 86 0
   Position 106 418
   Flags NoReliefString
   Type PushButton
   LocaleTitle {Save}
   Main
      Case message of
      SingleClic :
      Begin
         SendSignal 50 1
         SendSignal 51 1
      End
End

Widget 3
   Property
   Size 86 0
   Position 424 418
   Flags NoReliefString
   Type PushButton
   LocaleTitle {Close}
   Main
      Case message of
      SingleClic :
      Begin
         Quit
      End
End

Widget 4
   Property
   Size 86 0
   Position 328 418
   Flags NoReliefString
   Type PushButton
   LocaleTitle {Help}
   Main
      Case message of
      SingleClic :
      Begin
         Do {f_Notifier "Default Applications Manager" "Dismiss" "NsCDE/Info.xpm" \
            "Use this dialog to set default applications for common tasks. \
Select the desired application from each dropdown menu, then click Apply to test \
or Save to write changes to your NsCDE.conf configuration file."}
      End
End

