# Handler widget for Apply/Save signals
Widget 50
   Property
   Position 0 0
   Type Menu
   Flags NoReliefString Left Hidden
   Value 0
   Title {}
   Main
      Case message of
      SingleClic :
      Begin
      End
      1 :
      Begin
         # Apply: set infostore values
         Set $TermNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G terminal } (GetValue 20)) 1 -1)
         Set $EditorNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G text-editor } (GetValue 21)) 1 -1)
         Set $FileMgrNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G filemgr } (GetValue 22)) 1 -1)
         Set $BrowserNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G www-browser } (GetValue 23)) 1 -1)
         Set $MailNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G mailreader } (GetValue 24)) 1 -1)
         Set $TaskNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G taskmgr } (GetValue 25)) 1 -1)
         Set $CalcNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G calculator } (GetValue 26)) 1 -1)
         Set $PrintNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G printmgr } (GetValue 27)) 1 -1)

         # Apply via FVWM InfoStoreAdd
         Do {InfoStoreAdd terminal "} $TermNew {"}
         Do {InfoStoreAdd xeditor "} $EditorNew {"}
         Do {InfoStoreAdd filemgr "} $FileMgrNew {"}
         Do {InfoStoreAdd browser "} $BrowserNew {"}
         Do {InfoStoreAdd mailreader "} $MailNew {"}
         Do {InfoStoreAdd taskmgr "} $TaskNew {"}
         Do {InfoStoreAdd calculator "} $CalcNew {"}
         Do {InfoStoreAdd printmgr "} $PrintNew {"}

         # Update status
         ChangeTitle 30 (Gettext {Applied. Changes are active for this session.})
         Do {Schedule 3000 SendToModule DefaultAppsMgr SendString 30 2 clearstatus}
      End
      2 :
      Begin
         If (LastString) == {clearstatus} Then
            ChangeTitle 30 {}
      End
End

# Handler widget for Save signal
Widget 51
   Property
   Position 0 0
   Type Menu
   Flags NoReliefString Left Hidden
   Value 0
   Title {}
   Main
      Case message of
      SingleClic :
      Begin
      End
      1 :
      Begin
         # Save to NsCDE.conf using ised
         Set $TermNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G terminal } (GetValue 20)) 1 -1)
         Set $EditorNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G text-editor } (GetValue 21)) 1 -1)
         Set $FileMgrNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G filemgr } (GetValue 22)) 1 -1)
         Set $BrowserNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G www-browser } (GetValue 23)) 1 -1)
         Set $MailNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G mailreader } (GetValue 24)) 1 -1)
         Set $TaskNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G taskmgr } (GetValue 25)) 1 -1)
         Set $CalcNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G calculator } (GetValue 26)) 1 -1)
         Set $PrintNew = (GetOutput {$NSCDE_TOOLSDIR/appfinder -G printmgr } (GetValue 27)) 1 -1)

         # Save terminal
         Set $SaveTermCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd terminal .*/InfoStoreAdd terminal } $TermNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveTermCmd -1 1

         # Save editor
         Set $SaveEditorCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd xeditor .*/InfoStoreAdd xeditor } $EditorNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveEditorCmd -1 1

         # Save file manager
         Set $SaveFileMgrCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd filemgr .*/InfoStoreAdd filemgr } $FileMgrNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveFileMgrCmd -1 1

         # Save browser
         Set $SaveBrowserCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd browser .*/InfoStoreAdd browser } $BrowserNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveBrowserCmd -1 1

         # Save mail reader
         Set $SaveMailCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd mailreader .*/InfoStoreAdd mailreader } $MailNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveMailCmd -1 1

         # Save task manager
         Set $SaveTaskCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd taskmgr .*/InfoStoreAdd taskmgr } $TaskNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveTaskCmd -1 1

         # Save calculator
         Set $SaveCalcCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd calculator .*/InfoStoreAdd calculator } $CalcNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SaveCalcCmd -1 1

         # Save print manager
         Set $SavePrintCmd = {$NSCDE_TOOLSDIR/ised -c "s/InfoStoreAdd printmgr .*/InfoStoreAdd printmgr } $PrintNew {/g" -f "$FVWM_USERDIR/NsCDE.conf"}
         GetOutput $SavePrintCmd -1 1

         # Update status
         ChangeTitle 30 (Gettext {Saved to NsCDE.conf. Changes will persist after restart.})
         Do {Schedule 3000 SendToModule DefaultAppsMgr SendString 30 2 clearstatus}
      End
End
